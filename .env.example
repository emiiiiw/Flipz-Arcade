FLEECA_API_KEY=
# Webhook HMAC uses FLEECA_API_KEY (see app/api/webhook/route.ts)
# Server-only — never use in NEXT_PUBLIC_* or client code

# Optional Supabase player lookup (falls back to Prisma Session)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_in_production
DATABASE_URL="postgresql://user:password@localhost:5432/flipz?schema=public"
SESSION_SECRET="replace_with_32_plus_random_bytes_hex_or_string"
BASE_URL="http://localhost:3000"
